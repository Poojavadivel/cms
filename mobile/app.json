{
    "expo": {
        "name": "HMS Mobile",
        "slug": "hms-mobile",
        "version": "1.0.0",
        "orientation": "portrait",
        "icon": "./assets/icon.png",
        "userInterfaceStyle": "light",
        "newArchEnabled": true,
        "splash": {
            "image": "./assets/splash-icon.png",
            "resizeMode": "contain",
            "backgroundColor": "#0F172A"
        },
        "ios": {
            "supportsTablet": true,
            "bundleIdentifier": "com.movihospital.hms"
        },
        "android": {
            "adaptiveIcon": {
                "foregroundImage": "./assets/adaptive-icon.png",
                "backgroundColor": "#0F172A"
            },
            "package": "com.movihospital.hms",
            "usesCleartextTraffic": true
        },
        "web": {
            "bundler": "metro"
        },
        "plugins": [
            "expo-secure-store",
            "expo-font"
        ],
        "extra": {
            "eas": {
                "projectId": "00000000-0000-0000-0000-000000000000"
            }
        }
    }
}