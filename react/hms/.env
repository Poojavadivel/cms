# Environment Configuration
# Hospital Management System - React Frontend

# API Base URL (include /api suffix to match backend structure)
# Use localhost for local development, render.com for production
REACT_APP_API_URL=http://localhost:5000/api

# Optional: Enable debug mode
REACT_APP_DEBUG=true

# Optional: API timeout (milliseconds)
REACT_APP_API_TIMEOUT=30000

# Enable API Logging
REACT_APP_ENABLE_API_LOGS=true

# App Version
REACT_APP_VERSION=1.0.0
