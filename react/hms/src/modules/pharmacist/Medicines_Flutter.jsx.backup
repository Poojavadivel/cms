import React, { useState, useEffect } from 'react';
import { authService } from '../../services';
import {
  MdSearch,
  MdRefresh,
  MdAddCircle,
  MdChevronLeft,
  MdChevronRight,
} from 'react-icons/md';
import './Medicines_Flutter.css';

// Custom SVG Icons (matching other modules)
const Icons = {
  Eye: () => (
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
      <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
      <circle cx="12" cy="12" r="3"></circle>
    </svg>
  ),
  Edit: () => (
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
      <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
      <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
    </svg>
  ),
  Delete: () => (
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
      <polyline points="3 6 5 6 21 6"></polyline>
      <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
    </svg>
  ),
};

const PharmacistMedicines = () => {
  const [medicines, setMedicines] = useState([]);
  const [isLoading, setIsLoading] = useState(false);
  const [errorMessage, setErrorMessage] = useState(null);
  const [searchQuery, setSearchQuery] = useState('');
  const [filterStatus, setFilterStatus] = useState('All');
  const [showAddDialog, setShowAddDialog] = useState(false);
  const [selectedMedicine, setSelectedMedicine] = useState(null);
  const [currentPage, setCurrentPage] = useState(0);

  const itemsPerPage = 10;

  useEffect(() => {
    loadMedicines();
  }, []);

  const toInt = (value) => {
    if (value == null) return 0;
    if (typeof value === 'number') return Math.floor(value);
    if (typeof value === 'string') return parseInt(value) || 0;
    return 0;
  };

  const loadMedicines = async () => {
    setIsLoading(true);
    setErrorMessage(null);
    
    try {
      console.log('🔄 [Pharmacist] Loading medicines from API...');
      const response = await authService.get('/pharmacy/medicines?limit=100');
      console.log('✅ [Pharmacist] Received response:', response);
      
      // Normalize response
      let medicinesData = [];
      if (Array.isArray(response)) {
        medicinesData = response;
      } else if (response && typeof response === 'object') {
        medicinesData = response.medicines || response.data || [];
      }
      
      console.log('✅ [Pharmacist] Extracted medicines:', medicinesData.length);
      
      // Normalize the data
      const normalizedMedicines = medicinesData.map(med => {
        const stock = toInt(med.availableQty || med.stock || med.quantity || 0);
        return {
          _id: med._id || '',
          name: med.name || 'Unknown',
          sku: med.sku || '',
          category: med.category || '',
          manufacturer: med.manufacturer || '',
          status: med.status || 'In Stock',
          form: med.form || 'Tablet',
          strength: med.strength || '',
          availableQty: stock,
          reorderLevel: toInt(med.reorderLevel || 20),
        };
      });
      
      setMedicines(normalizedMedicines);
    } catch (error) {
      console.error('❌ [Pharmacist] Error loading medicines:', error);
      setErrorMessage(`Failed to load medicines: ${error.message || 'Request failed'}`);
    } finally {
      setIsLoading(false);
    }
  };

  const getFilteredMedicines = () => {
    const query = searchQuery.toLowerCase();
    
    let filtered = medicines.filter(med => {
      // Search filter
      const name = (med.name || '').toLowerCase();
      const sku = (med.sku || '').toLowerCase();
      const category = (med.category || '').toLowerCase();
      const matchesSearch = !query || name.includes(query) || sku.includes(query) || category.includes(query);
      
      // Stock status filter
      const stock = med.availableQty || 0;
      const reorderLevel = med.reorderLevel || 20;
      
      const matchesStatus = filterStatus === 'All' ||
        (filterStatus === 'In Stock' && stock > reorderLevel) ||
        (filterStatus === 'Low Stock' && stock > 0 && stock <= reorderLevel) ||
        (filterStatus === 'Out of Stock' && stock <= 0);
      
      return matchesSearch && matchesStatus;
    });

    return filtered;
  };

  const filteredMedicines = getFilteredMedicines();
  const startIndex = currentPage * itemsPerPage;
  const endIndex = Math.min(startIndex + itemsPerPage, filteredMedicines.length);
  const paginatedMedicines = filteredMedicines.slice(startIndex, endIndex);
  const totalPages = Math.ceil(filteredMedicines.length / itemsPerPage);

  const handlePreviousPage = () => {
    if (currentPage > 0) setCurrentPage(prev => prev - 1);
  };

  const handleNextPage = () => {
    if (currentPage < totalPages - 1) setCurrentPage(prev => prev + 1);
  };

  const getStockStatus = (stock, reorderLevel) => {
    if (stock <= 0) {
      return { label: 'Out of Stock', color: 'danger', icon: <MdBlock size={16} /> };
    }
    if (stock <= reorderLevel) {
      return { label: 'Low Stock', color: 'warning', icon: <MdWarning size={16} /> };
    }
    return { label: 'In Stock', color: 'success', icon: <MdCheckCircle size={16} /> };
  };

  const getStats = () => {
    const totalMedicines = medicines.length;
    const lowStock = medicines.filter(m => {
      const stock = m.availableQty || 0;
      const reorder = m.reorderLevel || 20;
      return stock > 0 && stock <= reorder;
    }).length;
    const outOfStock = medicines.filter(m => (m.availableQty || 0) <= 0).length;

    return { totalMedicines, lowStock, outOfStock };
  };

  const handleAddMedicine = () => {
    setSelectedMedicine(null);
    setShowAddDialog(true);
  };

  const handleEditMedicine = (medicine) => {
    setSelectedMedicine(medicine);
    setShowAddDialog(true);
  };

  const handleDeleteMedicine = async (medicine) => {
    if (!window.confirm(`Are you sure you want to delete ${medicine.name}?`)) {
      return;
    }

    try {
      await authService.delete(`/pharmacy/medicines/${medicine._id}`);
      loadMedicines(); // Reload list
    } catch (error) {
      console.error('Error deleting medicine:', error);
      alert('Failed to delete medicine');
    }
  };

  const handleSaveMedicine = async (medicineData) => {
    try {
      if (selectedMedicine) {
        // Update existing
        await authService.put(`/pharmacy/medicines/${selectedMedicine._id}`, medicineData);
      } else {
        // Create new
        await authService.post('/pharmacy/medicines', medicineData);
      }
      setShowAddDialog(false);
      loadMedicines(); // Reload list
    } catch (error) {
      console.error('Error saving medicine:', error);
      throw error;
    }
  };

  const filteredMedicines = getFilteredMedicines();
  const stats = getStats();

  return (
    <div className="flutter-medicines-page">
      {/* Header */}
      <div className="flutter-med-header">
        <div className="flutter-med-header-left">
          <MdLocalPharmacy size={28} color="#4f46e5" />
          <h1 className="flutter-med-title">Medicine Inventory</h1>
        </div>
        <div className="flutter-med-stats-card">
          <div className="flutter-med-stat-item">
            <span className="flutter-med-stat-value">{stats.totalMedicines}</span>
            <span className="flutter-med-stat-label">Total</span>
          </div>
          <div className="flutter-med-divider"></div>
          <div className="flutter-med-stat-item">
            <span className="flutter-med-stat-value flutter-stat-warning">{stats.lowStock}</span>
            <span className="flutter-med-stat-label">Low</span>
          </div>
          <div className="flutter-med-divider"></div>
          <div className="flutter-med-stat-item">
            <span className="flutter-med-stat-value flutter-stat-danger">{stats.outOfStock}</span>
            <span className="flutter-med-stat-label">Out</span>
          </div>
        </div>
      </div>

      {/* Search and Filter */}
      <div className="flutter-med-search-section">
        <div className="flutter-med-search-box">
          <MdSearch size={20} className="flutter-search-icon" />
          <input
            type="text"
            placeholder="Search by name, SKU, or category..."
            value={searchQuery}
            onChange={(e) => setSearchQuery(e.target.value)}
            className="flutter-search-input"
          />
        </div>
        
        <select
          value={filterStatus}
          onChange={(e) => setFilterStatus(e.target.value)}
          className="flutter-filter-dropdown"
        >
          <option value="All">All</option>
          <option value="In Stock">In Stock</option>
          <option value="Low Stock">Low Stock</option>
          <option value="Out of Stock">Out of Stock</option>
        </select>

        <button
          onClick={handleAddMedicine}
          className="flutter-add-btn"
          title="Add Medicine"
        >
          <MdAddCircle size={20} />
          <span>Add</span>
        </button>

        <button
          onClick={loadMedicines}
          className="flutter-refresh-btn"
          disabled={isLoading}
          title="Refresh"
        >
          <MdRefresh size={20} />
        </button>
      </div>

      {/* Medicines List */}
      <div className="flutter-med-list-container">
        {isLoading ? (
          <div className="flutter-med-skeleton">
            {/* Table Header Skeleton */}
            <div className="flutter-table-header">
              <div className="skeleton-table-header">
                <div className="skeleton skeleton-text" style={{ width: '150px' }}></div>
                <div className="skeleton skeleton-text" style={{ width: '100px' }}></div>
                <div className="skeleton skeleton-text" style={{ width: '80px' }}></div>
                <div className="skeleton skeleton-text" style={{ width: '60px' }}></div>
                <div className="skeleton skeleton-text" style={{ width: '100px' }}></div>
              </div>
            </div>
            
            {/* Table Rows Skeleton */}
            <div className="skeleton-table-body">
              {[1, 2, 3, 4, 5, 6, 7, 8].map((i) => (
                <div key={i} className="skeleton-table-row">
                  <div style={{ flex: 3 }}>
                    <div className="skeleton skeleton-text" style={{ width: '80%', marginBottom: '6px' }}></div>
                    <div className="skeleton skeleton-text-sm" style={{ width: '50%' }}></div>
                  </div>
                  <div style={{ flex: 2 }}>
                    <div className="skeleton skeleton-text" style={{ width: '70%' }}></div>
                  </div>
                  <div style={{ flex: 2 }}>
                    <div className="skeleton skeleton-text" style={{ width: '60%' }}></div>
                  </div>
                  <div style={{ flex: 1, display: 'flex', justifyContent: 'center' }}>
                    <div className="skeleton skeleton-badge-sm"></div>
                  </div>
                  <div style={{ flex: 2, display: 'flex', justifyContent: 'center' }}>
                    <div className="skeleton skeleton-status-badge"></div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        ) : errorMessage ? (
          <div className="flutter-med-error">
            <MdWarning size={64} color="#ef4444" />
            <h2>Error Loading Medicines</h2>
            <p>{errorMessage}</p>
            <button onClick={loadMedicines} className="flutter-retry-btn">
              Retry
            </button>
          </div>
        ) : filteredMedicines.length === 0 ? (
          <div className="flutter-med-empty">
            <MdLocalPharmacy size={64} color="#9ca3af" />
            <h2>No Medicines Found</h2>
            <p>Try adjusting your search or filter</p>
          </div>
        ) : (
          <div className="flutter-med-table-wrapper">
            <table className="flutter-med-table">
              <thead>
                <tr className="flutter-table-header">
                  <th>Medicine Name</th>
                  <th>Category</th>
                  <th>SKU</th>
                  <th className="flutter-th-center">Stock</th>
                  <th className="flutter-th-center">Status</th>
                </tr>
              </thead>
              <tbody>
                {filteredMedicines.map((medicine, index) => {
                  const status = getStockStatus(medicine.availableQty, medicine.reorderLevel);
                  const isEven = index % 2 === 0;
                  
                  return (
                    <tr 
                      key={medicine._id || index} 
                      className={isEven ? 'flutter-row-even' : 'flutter-row-odd'}
                      onClick={() => handleEditMedicine(medicine)}
                      style={{ cursor: 'pointer' }}
                      title="Click to edit"
                    >
                      <td className="flutter-td-name">
                        <div className="flutter-med-name">{medicine.name}</div>
                        {medicine.strength && (
                          <div className="flutter-med-strength">{medicine.strength}</div>
                        )}
                      </td>
                      <td className="flutter-td-category">{medicine.category || 'N/A'}</td>
                      <td className="flutter-td-sku">{medicine.sku || 'N/A'}</td>
                      <td className="flutter-td-center">
                        <span className={`flutter-stock-badge flutter-stock-${status.color}`}>
                          {medicine.availableQty}
                        </span>
                      </td>
                      <td className="flutter-td-center">
                        <span className={`flutter-status-badge flutter-status-${status.color}`}>
                          {status.icon}
                          <span>{status.label}</span>
                        </span>
                      </td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        )}
      </div>
    </div>
  );
};

export default PharmacistMedicines;
