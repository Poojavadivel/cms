    {
      "parameters": {
        "functionCode": "// Normalize OCR + caption into a single object\nconst filename = $binary ? Object.keys($binary)[0] : (item.filename || 'image');\nconst ocr = $json[\"stdout\"] || $json.ocr || '';\nlet caption = '';\n\ntry {\n  const hf = $json[\"body\"] || $json;\n  if(typeof hf === 'string') caption = hf;\n  else if(hf && hf[0] && hf[0].generated_text) caption = hf[0].generated_text;\n  else if(hf && hf.caption) caption = hf.caption;\n} catch (e) { caption = ''; }\n\nreturn [{ json: { filename, ocr, caption } }];"
      },
      "name": "Normalize",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [
        1250,
        250
