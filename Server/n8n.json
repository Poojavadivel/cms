    {
      "parameters": {
        "functionCode": "// Build prompt JSON for HF text model\nconst data = items[0].json || {};\nconst images = data.images || items.map(i=>i.json).slice(0,10);\nconst lang = data.lang || 'en';\nconst ocrTexts = images.map((it,i)=>`Image ${i+1} - filename: ${it.filename || ''}\\nCaption: ${it.caption || 'N/A'}\\nOCR: ${it.ocr || 'N/A'}`).join('\\n\\n');\n\nconst prompt = `You are an advanced AI tutor and educational content creator for engineering students.\\n\\nAnalyze the following extracted content from up to 10 images.\\n\\n${ocrTexts}\\n\\nRespond ONLY in valid JSON with keys: topic_title, core_explanation, easy_example, visual_aid, summary_points, quiz_questions, keywords, sources. Use ${lang === 'ta' ? 'Tamil' : 'English'}.\\n\\nIf uncertain about a fact, prefix that line with ⚠️.`;\n\nreturn [{ json: { prompt, lang } }];"
      },
      "name": "Build Prompt",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [
        1720,
        250
      ],
      "id": "build-prompt-0009"
    },
    {
      "parameters": {
        "url": "=https://api-inference.huggingface.co/models/google/flan-t5-large",
        "method": "POST",
        "authentication": "headerAuth",
        "headerParametersUi": {
          "parameter": [
            {
              "name": "Authorization",
              "value": "Bearer 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"
