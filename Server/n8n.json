      "name": "Text Generation (HuggingFace)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 1,
      "position": [
        1980,
        250
      ],
      "id": "text-generation-hf-0010"
    },
    {
      "parameters": {
        "functionCode": "// Try to parse model text into JSON\nlet body = $json.body || $json;\nlet text = '';\nif(typeof body === 'string') text = body;\nelse if(body.generated_text) text = body.generated_text;\nelse if(body[0] && body[0].generated_text) text = body[0].generated_text;\nelse if(body.data && body.data[0] && body.data[0].text) text = body.data[0].text;\n\n// attempt to find JSON inside text\nconst start = text.indexOf('{');\nconst end = text.lastIndexOf('}');\nif(start !== -1 && end !== -1) {\n  const jsonStr = text.slice(start, end+1);\n  try {\n    const parsed = JSON.parse(jsonStr);\n    return [{ json: parsed }];\n  } catch(e) {\n    return [{ json: { error: 'failed_parse', raw: text } }];\n  }\n}\nreturn [{ json: { error: 'no_json', raw: text } }];"
      },
