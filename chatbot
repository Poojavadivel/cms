```javascript
// Add to bot
bot.onText(/\/health/, (msg) => {
  const uptime = process.uptime();
  const memory = process.memoryUsage();
  bot.sendMessage(msg.chat.id, 
    `✅ Bot is running\n⏱ Uptime: ${Math.floor(uptime/3600)}h\n💾 Memory: ${Math.round(memory.heapUsed/1024/1024)}MB`
  );
});
