```

### Emergency Slots
Reserve specific slots for emergencies:

```javascript
const reservedSlots = ['09:00', '14:00']; // Reserved for emergencies
const availableSlots = allSlots.filter(slot => 
  !bookedSlots.includes(slot) && !reservedSlots.includes(slot)
);
```

### Appointment Reminders
Add a cron job to send reminders:

```javascript
const cron = require('node-cron');

// Run every day at 8 AM
cron.schedule('0 8 * * *', async () => {
  const tomorrow = new Date();
  tomorrow.setDate(tomorrow.getDate() + 1);
  tomorrow.setHours(0, 0, 0, 0);
  
  const appointments = await Appointment.find({
    startAt: { 
      $gte: tomorrow, 
      $lt: new Date(tomorrow.getTime() + 24*60*60*1000) 
    },
    status: 'Scheduled',
    bookingSource: 'telegram'
  }).populate('patientId');
  
  for (const apt of appointments) {
    const chatId = apt.metadata.telegramChatId;
    if (chatId) {
      bot.sendMessage(chatId, 
        `🔔 Reminder: You have an appointment tomorrow at ${formatTime(apt.startAt)}`
      );
    }
  }
});
```

## Performance Optimization

### Index Management
Add these indexes for better performance:

```javascript
// Appointments
db.appointments.createIndex({ doctorId: 1, startAt: 1 });
db.appointments.createIndex({ patientId: 1, startAt: -1 });
db.appointments.createIndex({ bookingSource: 1 });
db.appointments.createIndex({ status: 1, startAt: 1 });

// Users
db.users.createIndex({ role: 1, is_active: 1 });

// Patients
db.patients.createIndex({ phone: 1 });
db.patients.createIndex({ 'metadata.telegramChatId': 1 });
```

### Conversation State with Redis
For production, use Redis instead of in-memory Map:

```javascript
const Redis = require('ioredis');
const redis = new Redis(process.env.REDIS_URL);

async function getConversation(chatId) {
  const data = await redis.get(`conv:${chatId}`);
  return data ? JSON.parse(data) : { state: STATES.IDLE, data: {} };
}

async function updateConversation(chatId, updates) {
  const conv = await getConversation(chatId);
  Object.assign(conv, updates);
  await redis.setex(`conv:${chatId}`, 3600, JSON.stringify(conv)); // 1 hour TTL
}
```

## Security Best Practices

1. **Validate User Input**: Already implemented
2. **Rate Limiting**: Add rate limiting per chat ID
3. **Authentication**: Verify bot token
4. **Data Sanitization**: Sanitize before database operations
5. **Secure Storage**: Never log sensitive patient data
6. **HIPAA Compliance**: Ensure Telegram usage complies with regulations

## Backup and Recovery

### Backup Appointments
```bash
mongodump --db karur_hms --collection appointments --out /backup/
```

### Restore Appointments
```bash
mongorestore --db karur_hms --collection appointments /backup/karur_hms/appointments.bson
```

